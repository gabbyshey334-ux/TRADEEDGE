NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key

# Required server-side for the Stripe webhook (do NOT expose to the client).
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

NEXT_PUBLIC_APP_URL=http://localhost:3000

# Anthropic Claude — powers the AI Coach reports. Get from https://console.anthropic.com
ANTHROPIC_API_KEY=sk-ant-your-key-here

# Financial Modeling Prep — powers the live Congressional Trades feed.
# Get a key from https://site.financialmodelingprep.com/developer/docs
FMP_API_KEY=your_fmp_api_key_here

# Stripe — get these from https://dashboard.stripe.com (test mode).
STRIPE_SECRET_KEY=sk_test_...
STRIPE_WEBHOOK_SECRET=whsec_...
STRIPE_STARTER_PRICE_ID=price_...
STRIPE_PRO_PRICE_ID=price_...
STRIPE_ELITE_PRICE_ID=price_...
